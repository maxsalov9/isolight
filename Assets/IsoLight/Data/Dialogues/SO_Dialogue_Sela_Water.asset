  m_Script: {fileID: 11500000, guid: 7d88b49fb50845489e9ed6fc0b6581e8, type: 3}
  m_Name: SO_Dialogue_Sela_Water
  m_EditorClassIdentifier: Assembly-CSharp::IsoLight.Dialogue.DialogueData
  Id: D03_SELA_WATER
  SpeakerName: Sela
  StartNodeId: start
  Nodes:
  - NodeId: start
    SpeakerId: sela
    SpeakerName: Sela
    Text: "\u041D\u0435 \u0441\u043C\u043E\u0442\u0440\u0438\u0442\u0435 \u0442\u0430\u043A.
      \u042D\u0442\u0430 \u0432\u043E\u0434\u0430 \u0442\u043E\u043B\u044C\u043A\u043E
      \u043F\u0440\u0438\u0442\u0432\u043E\u0440\u044F\u043B\u0430\u0441\u044C \u0447\u0438\u0441\u0442\u043E\u0439."
    CompanionComment: 
    Choices:
    - Text: "\u041E\u043D\u0430 \u0432\u044B\u0433\u043B\u044F\u0434\u0435\u043B\u0430
        \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E."
      NextNodeId: argument
      Conditions: []
      Effects: []
    - Text: "\u0412\u044B \u0432\u0440\u0430\u0447?"
      NextNodeId: argument
      Conditions: []
      Effects: []
    - Text: "Cormac, \u0447\u0442\u043E \u0432\u0438\u0434\u0438\u0448\u044C?"
      NextNodeId: argument
      Conditions: []
      Effects: []
    Effects: []
  - NodeId: argument
    SpeakerId: sela
    SpeakerName: Sela
    Text: "\u041A\u043E\u0433\u0434\u0430 \u0431\u0443\u0434\u0435\u0442\u0435 \u0432\u044B\u0431\u0438\u0440\u0430\u0442\u044C,
      \u043D\u0435 \u0434\u0443\u043C\u0430\u0439\u0442\u0435 \u043E \u0442\u0440\u0443\u0431\u0430\u0445.
      \u0414\u0443\u043C\u0430\u0439\u0442\u0435 \u043E \u0442\u043E\u043C, \u0441\u043A\u043E\u043B\u044C\u043A\u043E
      \u043B\u044E\u0434\u0435\u0439 \u0443\u0436\u0435 \u043D\u043E\u0441\u044F\u0442
      \u043F\u043B\u043E\u0445\u0443\u044E \u0432\u043E\u0434\u0443 \u0432\u043D\u0443\u0442\u0440\u0438
      \u0441\u0435\u0431\u044F."
    CompanionComment: "Cormac: \u041D\u0438 \u0437\u0430\u043F\u0430\u0445\u0430,
      \u043D\u0438 \u0446\u0432\u0435\u0442\u0430. \u042D\u0442\u043E \u0445\u0443\u0436\u0435,
      \u0447\u0435\u043C \u0433\u0440\u044F\u0437\u044C."
    Choices:
    - Text: "\u041A\u0438\u043F\u044F\u0447\u0435\u043D\u0438\u0435 \u043D\u0435
        \u043F\u043E\u043C\u043E\u0433\u0430\u0435\u0442?"
      NextNodeId: 
      Conditions: []
      Effects:
      - Type: 1
        Key: talked_to_sela
        BoolValue: 1
        Quest: {fileID: 0}
    - Text: "\u041D\u0430\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0432\u0441\u0435
        \u043F\u043B\u043E\u0445\u043E?"
      NextNodeId: 
      Conditions: []
      Effects:
      - Type: 1
        Key: talked_to_sela
        BoolValue: 1
        Quest: {fileID: 0}
    - Text: "\u041C\u044B \u0443\u0447\u0442\u0435\u043C \u0444\u0438\u043B\u044C\u0442\u0440\u044B."
      NextNodeId: 
      Conditions: []
      Effects:
      - Type: 1
        Key: talked_to_sela
        BoolValue: 1
        Quest: {fileID: 0}
    Effects: []
