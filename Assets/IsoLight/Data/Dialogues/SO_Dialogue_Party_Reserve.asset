  m_Script: {fileID: 11500000, guid: 7d88b49fb50845489e9ed6fc0b6581e8, type: 3}
  m_Name: SO_Dialogue_Party_Reserve
  m_EditorClassIdentifier: Assembly-CSharp::IsoLight.Dialogue.DialogueData
  Id: D08_PARTY_RESERVE
  SpeakerName: Party Reserve
  StartNodeId: start
  Nodes:
  - NodeId: start
    SpeakerId: nyra
    SpeakerName: Nyra
    Text: "\u041C\u044B \u043C\u043E\u0436\u0435\u043C \u0432\u0437\u044F\u0442\u044C
      \u0440\u0435\u0437\u0435\u0440\u0432\u043D\u044B\u0439 \u0437\u0430\u0440\u044F\u0434."
    CompanionComment: 
    Choices:
    - Text: "\u041D\u0430 \u0447\u0442\u043E \u043F\u043E\u0439\u0434\u0435\u0442
        \u0440\u0435\u0437\u0435\u0440\u0432?"
      NextNodeId: argument
      Conditions: []
      Effects: []
    - Text: "\u0421\u043A\u043E\u043B\u044C\u043A\u043E \u043F\u043E\u0442\u0435\u0440\u044F\u0435\u0442
        Riverside?"
      NextNodeId: argument
      Conditions: []
      Effects: []
    - Text: "\u041C\u043E\u0436\u043D\u043E \u0441\u0434\u0435\u043B\u0430\u0442\u044C
        \u044D\u0442\u043E \u043D\u0435\u0437\u0430\u043C\u0435\u0442\u043D\u043E?"
      NextNodeId: argument
      Conditions: []
      Effects: []
    Effects: []
  - NodeId: argument
    SpeakerId: nyra
    SpeakerName: Party Reserve
    Text: "\u042F \u043E\u0441\u0442\u0430\u0432\u043B\u044E \u044F\u0447\u0435\u0439\u043A\u0438
      \u043F\u043E\u0434\u043A\u043B\u044E\u0447\u0435\u043D\u043D\u044B\u043C\u0438,
      \u043D\u043E \u043D\u0435 \u0430\u043A\u0442\u0438\u0432\u043D\u044B\u043C\u0438.
      \u0420\u0435\u0448\u0435\u043D\u0438\u0435 \u0437\u0430 \u0442\u043E\u0431\u043E\u0439."
    CompanionComment: "Cormac: \u041F\u043B\u043E\u0445\u0430\u044F \u0444\u0440\u0430\u0437\u0430,
      \u0447\u0442\u043E\u0431\u044B \u043D\u0430 \u043D\u0435\u0439 \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u0442\u044C."
    Choices:
    - Text: "\u042D\u043D\u0435\u0440\u0433\u0438\u044F \u043E\u0441\u0442\u0430\u0435\u0442\u0441\u044F
        \u0437\u0434\u0435\u0441\u044C."
      NextNodeId: 
      Conditions: []
      Effects: []
    - Text: "\u0417\u0430\u043F\u043E\u043C\u043D\u0438\u043C \u044D\u0442\u043E\u0442
        \u0432\u0430\u0440\u0438\u0430\u043D\u0442."
      NextNodeId: 
      Conditions: []
      Effects: []
    Effects: []
