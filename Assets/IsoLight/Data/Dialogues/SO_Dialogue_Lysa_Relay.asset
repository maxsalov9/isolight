  m_Script: {fileID: 11500000, guid: 7d88b49fb50845489e9ed6fc0b6581e8, type: 3}
  m_Name: SO_Dialogue_Lysa_Relay
  m_EditorClassIdentifier: Assembly-CSharp::IsoLight.Dialogue.DialogueData
  Id: D07_LYSA_RELAY
  SpeakerName: Lysa
  StartNodeId: start
  Nodes:
  - NodeId: start
    SpeakerId: lysa
    SpeakerName: Lysa
    Text: "\u0421\u0435\u043A\u0443\u043D\u0434\u0443 \u043D\u0435 \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u0435.
      \u041F\u043E\u0434 \u0448\u0443\u043C\u043E\u043C \u0435\u0441\u0442\u044C
      \u043D\u0435\u0441\u0443\u0449\u0430\u044F."
    CompanionComment: 
    Choices:
    - Text: "\u041C\u044B \u043D\u0430\u0441\u0447\u0435\u0442 \u0440\u0435\u043B\u0435."
      NextNodeId: argument
      Conditions: []
      Effects: []
    - Text: "\u0422\u044B \u0441\u043B\u0443\u0448\u0430\u0435\u0448\u044C \u043F\u043E\u043C\u0435\u0445\u0438?"
      NextNodeId: argument
      Conditions: []
      Effects: []
    - Text: Nyra?
      NextNodeId: argument
      Conditions: []
      Effects: []
    Effects: []
  - NodeId: argument
    SpeakerId: lysa
    SpeakerName: Lysa
    Text: "\u0415\u0441\u043B\u0438 \u0434\u0430\u0434\u0438\u0442\u0435 \u043C\u043D\u0435
      \u043F\u0438\u0442\u0430\u043D\u0438\u0435, \u044F \u043C\u043E\u0433\u0443
      \u043D\u0435 \u0443\u0441\u043B\u044B\u0448\u0430\u0442\u044C \u043D\u0438\u0447\u0435\u0433\u043E.
      \u041D\u043E \u0435\u0441\u043B\u0438 \u043D\u0435 \u0434\u0430\u0434\u0438\u0442\u0435,
      \u043C\u044B \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0443\u0437\u043D\u0430\u0435\u043C,
      \u0436\u0434\u0430\u043B\u043E \u043B\u0438 \u044D\u0442\u043E \u043D\u0438\u0447\u0435\u0433\u043E
      \u043E\u0442\u0432\u0435\u0442\u0430."
    CompanionComment: "Nyra: \u041E\u043D\u0430 \u043F\u0440\u0430\u0432\u0430. \u041F\u043E\u0434
      \u0448\u0443\u043C\u043E\u043C \u0435\u0441\u0442\u044C \u043D\u0435\u0441\u0443\u0449\u0430\u044F."
    Choices:
    - Text: "\u0422\u044B \u043F\u0440\u043E Blind Protocol."
      NextNodeId: 
      Conditions: []
      Effects:
      - Type: 1
        Key: talked_to_lysa
        BoolValue: 1
        Quest: {fileID: 0}
    - Text: "\u041E\u043D\u043E \u043C\u043E\u0436\u0435\u0442 \u0441\u0432\u044F\u0437\u0430\u0442\u044C\u0441\u044F
        \u0441 \u0434\u0440\u0443\u0433\u0438\u043C \u043F\u043E\u0441\u0435\u043B\u0435\u043D\u0438\u0435\u043C?"
      NextNodeId: 
      Conditions: []
      Effects:
      - Type: 1
        Key: talked_to_lysa
        BoolValue: 1
        Quest: {fileID: 0}
    - Text: "\u041C\u044B \u0443\u0441\u043B\u044B\u0448\u0430\u043B\u0438 \u0440\u0435\u043B\u0435."
      NextNodeId: 
      Conditions: []
      Effects:
      - Type: 1
        Key: talked_to_lysa
        BoolValue: 1
        Quest: {fileID: 0}
    Effects: []
