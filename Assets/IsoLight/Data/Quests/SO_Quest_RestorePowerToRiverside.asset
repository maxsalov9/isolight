  Id: restore_power_to_riverside
  Title: Restore Power to Riverside
  Description: "\u041E\u0441\u043D\u043E\u0432\u043D\u0430\u044F \u043C\u0438\u0441\u0441\u0438\u044F
    Riverside: \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
    \u043F\u0438\u0442\u0430\u043D\u0438\u0435, \u0437\u0430\u0449\u0438\u0442\u0438\u0442\u044C
    \u0433\u0435\u043D\u0435\u0440\u0430\u0442\u043E\u0440 \u0438 \u043F\u0440\u0438\u043D\u044F\u0442\u044C
    \u0444\u0438\u043D\u0430\u043B\u044C\u043D\u043E\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u0435."
  Objectives:
  - Id: reach_riverside_shelter
    Description: "\u0414\u043E\u0431\u0440\u0430\u0442\u044C\u0441\u044F \u0434\u043E
      \u0443\u0431\u0435\u0436\u0438\u0449\u0430 Riverside"
    Status: 0
  - Id: speak_with_mara
    Description: "\u041F\u043E\u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C \u0441
      Mara Vey"
    Status: 0
  - Id: resolve_power_priorities
    Description: "\u0420\u0430\u0437\u043E\u0431\u0440\u0430\u0442\u044C\u0441\u044F
      \u0441 \u044D\u043D\u0435\u0440\u0433\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
      \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442\u0430\u043C\u0438 Riverside"
    Status: 0
  - Id: inspect_key_systems
    Description: "\u041E\u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
